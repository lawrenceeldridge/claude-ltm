#!/usr/bin/env python3
"""engram — inspect and drive claude-engram memory from the terminal.

Subcommands:
  doctor      show resolved config, project identity and fact count
  capture     capture memory from stdin / --file / --transcript
  recall      run a just-in-time recall query for the current project
  core        show the stable session-start memory block
  projects    list every project in the global store
  prune       delete all memory for the current project
  uninstall   uninstall the plugin, keeping memory (add --purge-data to remove it)
  import      migrate memory from another store (e.g. claude-mem) into engram
  daemon      run the resident daemon (keeps the embedder warm)
  viewer      launch the localhost viewer
  stats       recall telemetry + token-savings ledger (cost vs saved, net)
  replay      counterfactual token savings from past session transcripts
  drift       pin/check the embedding-drift canary
  demo        capture sample facts, then recall against them (end-to-end proof)
"""

from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

import _bootstrap  # noqa: E402

_bootstrap.reexec_if_pinned()
ROOT = Path(os.environ.get("CLAUDE_PLUGIN_ROOT") or Path(__file__).resolve().parent.parent)
sys.path.insert(0, str(ROOT))

from core import service  # noqa: E402
from core.config import get_config  # noqa: E402
from core.ports.embedding import get_embedder  # noqa: E402
from core.project import GLOBAL_PROJECT_KEY, resolve_project  # noqa: E402
from core.store import Store  # noqa: E402


def _project(cfg, args):
    return resolve_project(
        getattr(args, "cwd", None) or os.getcwd(),
        cfg.markers,
        identity=cfg.identity,
        project_dir=cfg.project_dir,
    )


def cmd_doctor(args) -> int:
    cfg = get_config()
    store = Store(cfg.db_path)
    project = _project(cfg, args)
    print(f"data dir  : {cfg.data_dir}")
    print(f"db        : {cfg.db_path}")
    print(f"embedding : {cfg.embedding} (dim={cfg.dim})")
    print(f"top_k={cfg.top_k}  min_sim={cfg.min_sim}  core_size={cfg.core_size}  max_chars={cfg.max_chars}")
    print(f"project   : {project['label']}  [{project['key']}]")
    print(f"            {project['path']}")
    print(f"facts     : {store.count()} total / {len(store.rows_for_project(project['key']))} in this project")
    ap_proj = len(store.active_antipatterns(project["key"]))
    ap_global = len(store.active_antipatterns(GLOBAL_PROJECT_KEY))
    print(f"antipatterns: {ap_proj} in this project / {ap_global} global")
    # Resolved consolidation config (env / userConfig overrides already applied) — 'off'
    # marks a disabled lever, so shipped defaults are never mistaken for the live state.
    print(
        f"consolidation: supersede={cfg.supersede_threshold}  "
        f"integrate={cfg.integrate_threshold or 'off'}  "
        f"stm_capacity={cfg.stm_capacity or 'off'} (promote>={cfg.promote_after_freq})"
    )
    print(
        f"forgetting  : refine_keep_max={cfg.refine_keep_max or 'off'}  "
        f"refine_prune_pct={cfg.refine_prune_percentile or 'off'}  "
        f"purge_days={cfg.purge_horizon_days or 'off'}  half_life_days={cfg.half_life_days}"
    )
    s = store.sensory_stats(project["key"])
    print(
        f"sensory     : {'on' if cfg.sensory_enabled else 'off'}  "
        f"{s['live']} live ({s['visual']} visual / {s['verbal']} verbal), {s['attended']} attended  "
        f"capacity={cfg.sensory_capacity or 'off'}  ttl={cfg.sensory_ttl_seconds or 'off'}s  "
        f"attention_window={cfg.attention_window_seconds}s"
    )
    store.close()
    return 0


def cmd_capture(args) -> int:
    cfg = get_config()
    store = Store(cfg.db_path)
    embedder = get_embedder(cfg)
    project = _project(cfg, args)
    session = args.session or "cli"
    if args.transcript:
        n = service.capture_transcript(store, embedder, cfg, project, session, args.transcript)
    elif args.file:
        text = Path(args.file).read_text(encoding="utf-8")
        n = service.capture_text(store, embedder, cfg, project, session, text)
    else:
        n = service.capture_text(store, embedder, cfg, project, session, sys.stdin.read())
    print(f"captured {n} new fact(s) into {project['label']}")
    store.close()
    return 0


def cmd_recall(args) -> int:
    cfg = get_config()
    store = Store(cfg.db_path)
    project = _project(cfg, args)
    block = service.recall_prompt_block(store, get_embedder(cfg), cfg, project, args.query)
    print(block or "(no relevant memory)")
    store.close()
    return 0


def cmd_core(args) -> int:
    cfg = get_config()
    store = Store(cfg.db_path)
    project = _project(cfg, args)
    print(service.recall_core_block(store, cfg, project) or "(no core memory)")
    store.close()
    return 0


def cmd_projects(_args) -> int:
    cfg = get_config()
    store = Store(cfg.db_path)
    rows = store.projects()
    if not rows:
        print("(no memory yet)")
    for row in rows:
        print(f"{row['c']:5d}  {row['project_label']:24s}  {row['project_path']}")
    store.close()
    return 0


def cmd_prune(args) -> int:
    cfg = get_config()
    store = Store(cfg.db_path)
    project = _project(cfg, args)
    n = store.prune_project(project["key"])
    print(f"pruned {n} fact(s) from {project['label']}")
    store.close()
    return 0


def cmd_uninstall(args) -> int:
    """Uninstall the plugin, KEEPING the memory store by default.

    `claude plugin uninstall` deletes the plugin data dir (store + provisioned venv)
    unless `--keep-data` is passed — so this wrapper always passes it, and only removes
    the data on an explicit `--purge-data`. Destruction is opt-in, never the default.
    """
    import shutil
    import subprocess

    cfg = get_config()
    data_dir = cfg.data_dir
    plugin_id = os.environ.get("ENGRAM_PLUGIN_ID", "engram@claude-engram")
    cmd = ["claude", "plugin", "uninstall", plugin_id, "--keep-data", "-y"]

    if args.dry_run:
        print("[dry-run] would run:", " ".join(cmd))
        print(f"[dry-run] would then {'PURGE' if args.purge_data else 'KEEP'} the store at {data_dir}")
        return 0

    print(f"uninstalling {plugin_id} (memory kept — the harness's --keep-data is always passed)…")
    try:
        rc = subprocess.run(cmd).returncode
    except OSError as exc:
        print(
            f"[engram] could not run `claude plugin uninstall` ({exc}); data left intact at {data_dir}", file=sys.stderr
        )
        rc = 1

    if args.purge_data:
        if data_dir.exists():
            shutil.rmtree(data_dir, ignore_errors=True)
            print(f"purged the memory store and venv at {data_dir}")
        else:
            print(f"nothing to purge — no data dir at {data_dir}")
    else:
        print(f"memory KEPT at {data_dir}")
        print(f"  remove it later with:  engram uninstall --purge-data   (or:  rm -rf {data_dir})")
    return rc


def cmd_sweep(args) -> int:
    import time

    cfg = get_config()
    days = args.days if args.days else cfg.ttl_days
    if days <= 0:
        print("TTL disabled — set ttl_days > 0 in config or pass --days N")
        return 0
    store = Store(cfg.db_path)
    scope = None if args.all else _project(cfg, args)["key"]
    n = store.sweep(time.time(), days * 86400, cfg.ttl_keep_frequency, scope)
    where = "all projects" if args.all else _project(cfg, args)["label"]
    print(f"expired {n} fact(s) older than {days:g}d (kept frequency >= {cfg.ttl_keep_frequency}) in {where}")
    store.close()
    return 0


def cmd_consolidate(args) -> int:
    import time
    from collections import defaultdict

    from core.consolidation import consolidate

    cfg = get_config()
    store = Store(cfg.db_path)
    embedder = get_embedder(cfg)  # for the integrate stage's LLM merge tier (no-op otherwise)
    now = time.time()
    if args.all:
        targets = [
            {"key": r["project_key"], "label": r["project_label"] or r["project_key"], "path": r["project_path"] or ""}
            for r in store.projects()
        ]
    else:
        targets = [_project(cfg, args)]
    # Route through the shared orchestrator so the CLI can't drift from the
    # checkpoint pass (bin/capture.py) — same stages, same order (replay →
    # displace → integrate → refine → purge), each gated/idempotent/reversible.
    # Totals are accumulated per stage the orchestrator reports, so a stage added
    # later (e.g. `merged`) flows through to the summary without touching this code.
    totals: dict[str, int] = defaultdict(int)
    for project in targets:
        counts = consolidate(store, cfg, project, now, embedder=embedder)
        for stage, n in counts.items():
            totals[stage] += n
    gated = (
        ""
        if (cfg.refine_keep_max > 0 or cfg.refine_prune_percentile > 0)
        else " (pruning off — set refine_keep_max/refine_prune_percentile)"
    )
    summary = ", ".join(f"{stage} {n}" for stage, n in totals.items()) or "no stages run"
    print(f"consolidated {len(targets)} project(s): {summary}{gated}")
    store.close()
    return 0


def cmd_setup(_args) -> int:
    from core.provision import provision

    cfg = get_config()
    return 0 if provision(cfg.data_dir) else 1


def cmd_daemon(_args) -> int:
    import runpy

    runpy.run_path(str(ROOT / "bin" / "daemon.py"), run_name="__main__")
    return 0


def cmd_viewer(args) -> int:
    import webbrowser

    from viewer.serve import ensure_viewer, serve, stop_viewer

    if args.stop:
        print("stopped resident viewer" if stop_viewer() else "no resident viewer running")
        return 0
    if args.ensure:
        ensure_viewer(args.port, str(ROOT))
        url = f"http://127.0.0.1:{args.port}/"
        print(f"[engram] viewer at {url}")
        if not args.no_open:
            try:
                webbrowser.open(url)
            except Exception:
                pass
        return 0
    serve(port=args.port, open_browser=not args.no_open)
    return 0


def cmd_stats(args) -> int:
    cfg = get_config()
    store = Store(cfg.db_path)
    scope = None if args.all else _project(cfg, args)["key"]
    where = "all projects" if args.all else _project(cfg, args)["label"]
    s = service.usage_summary(store, scope)
    r = s["recalls"]

    print(f"scope   : {where}")
    print(f"facts   : {store.count()} active")
    print(f"recalls : {r['total']} total  {r['by_verdict']}")
    print("token ledger (heuristic, ~4 chars/token):")
    print(
        f"  cost  — injected  : {s['injections']} injections, ~{s['cost_tokens']:,} tokens "
        f"(~{s['cost_tokens_cache_adjusted']:,} cache-adjusted)"
    )
    print(
        f"  saved — measured  : {s['targeted_reads']} targeted reads + "
        f"{s['bounded_reads']} bounded reads, "
        f"~{s['saved_measured_tokens']:,} tokens (whole-file reads avoided)"
    )
    print(
        f"  saved — estimated : {s['ok_recalls']} recall shortcuts, "
        f"~{s['saved_estimated_tokens']:,} tokens (heuristic, excluded from headline)"
    )
    print(f"  NET measured      : ~{s['net_measured_tokens']:,} tokens (measured saved − max cost view)")
    print(f"  NET incl. estimate: ~{s['net_tokens']:,} tokens")
    store.close()
    return 0


def cmd_queue(args) -> int:
    import time
    from collections import Counter

    cfg = get_config()
    store = Store(cfg.db_path)
    try:
        if args.purge_all:
            print(f"purged {store.purge_work()} work item(s) (all)")
            return 0
        if args.purge_dead:
            print(f"purged {store.purge_work(status='dead')} work item(s) (dead-letter)")
            return 0
        if args.purge_stage:
            print(f"purged {store.purge_work(stage=args.purge_stage)} work item(s) (stage={args.purge_stage})")
            return 0
        total = store.count_work()
        parts = [f"{s} {store.count_work(status=s)}" for s in ("pending", "in_progress", "dead")]
        print(f"work queue: {total} total  —  {', '.join(parts)}")
        if total:
            rows = store.recent_work(20) if args.all else store.work_items(_project(cfg, args)["key"], 20)
            by_stage = Counter(r["stage"] for r in rows)
            print("by stage:", ", ".join(f"{s} {n}" for s, n in by_stage.items()) or "(none)")
            now = time.time()
            for r in rows:
                age = (now - (r["enqueued_at"] or now)) / 86400
                print(
                    f"  {r['status']:<11} {r['stage']:<10} attempts={r['attempts']} age={age:.1f}d {r['msg_id'][:28]}"
                )
        return 0
    finally:
        store.close()


def cmd_drift(_args) -> int:
    from core.index.drift import check, pin

    cfg = get_config()
    embedder = get_embedder(cfg)
    model_id = f"{cfg.embedding}:{cfg.embedding_model or 'default'}:{embedder.dim}"
    result = check(embedder, cfg.data_dir, model_id)
    if result["status"] == "unpinned":
        pin(embedder, cfg.data_dir, model_id)
        print(f"pinned embedding canary for {model_id}")
        return 0
    print(f"drift status: {result['status']}")
    for key in ("mean_similarity", "threshold", "pinned_model", "current_model", "hint"):
        if result.get(key):
            print(f"  {key}: {result[key]}")
    return 1 if result["status"] in ("drift", "model_changed", "dim_changed") else 0


def cmd_eval(args) -> int:
    from bench.run_eval import main as run_eval

    return run_eval([b.strip() for b in args.backends.split(",") if b.strip()], stm=args.stm)


def cmd_replay(args) -> int:
    """Trace-driven counterfactual: replay past search sweeps against the index.

    Reads recorded session transcripts, finds Grep/Glob/whole-file-Read sweeps,
    re-queries the live index with each sweep's own search terms, and prices the
    indexed path against what the sweep actually cost. Conservative by design —
    see bench/replay.py.
    """
    from bench.replay import counterfactual, find_sweeps, parse_transcript, sweep_query
    from core.index.index_recall import get_chunk, search_index

    cfg = get_config()
    project = _project(cfg, args)
    tdir = Path(args.transcript_dir) if args.transcript_dir else _default_transcript_dir(project["path"])
    files = sorted(tdir.glob("*.jsonl")) if tdir.is_dir() else []
    if not files:
        print(f"no transcripts found in {tdir}")
        return 1

    store = Store(cfg.db_path)
    embedder = get_embedder(cfg)
    totals = {"sweeps": 0, "creditable": 0, "actual": 0, "indexed": 0, "saved": 0}
    skipped_files = 0
    try:
        for path in files:
            try:
                with path.open(encoding="utf-8", errors="replace") as fh:
                    sweeps = find_sweeps(parse_transcript(fh))
            except OSError:
                skipped_files += 1
                continue
            for sweep in sweeps:
                kind = "doc_section" if str(sweep["landing"]).endswith((".md", ".mdx")) else "code_symbol"
                try:
                    res = search_index(store, embedder, cfg, project, sweep_query(sweep), k=5, kind=kind)
                except Exception:
                    continue  # fail-soft: an unanswerable sweep earns no credit
                hits = res.get("results") or []
                hit_paths = [h.get("source_path") or "" for h in hits]
                outline_bytes = sum(len(str(h.get(f, ""))) for h in hits for f in ("anchor", "summary", "source_path"))
                body_bytes = 0
                landing = str(sweep["landing"])
                match = next((h for h in hits if h.get("source_path") and landing.endswith(h["source_path"])), None)
                if match:
                    try:
                        chunk = get_chunk(store, project, match.get("anchor") or "")
                        body_bytes = len(str(chunk.get("body") or ""))
                    except Exception:
                        body_bytes = 0
                result = counterfactual(sweep, hit_paths, outline_bytes, body_bytes)
                totals["sweeps"] += 1
                totals["creditable"] += result["creditable"]
                totals["actual"] += result["actual_tokens"]
                if result["creditable"]:
                    totals["indexed"] += result["indexed_tokens"]
                    totals["saved"] += result["saved_tokens"]
    finally:
        store.close()

    print(f"transcripts : {len(files)} files ({skipped_files} unreadable)")
    print(f"sweeps      : {totals['sweeps']} found, {totals['creditable']} creditable via the index")
    print(f"actual cost : ~{totals['actual']:,} tokens across all sweeps")
    if totals["creditable"]:
        print(f"indexed cost: ~{totals['indexed']:,} tokens for the creditable sweeps")
        print(f"SAVED       : ~{totals['saved']:,} tokens (counterfactual floor, creditable sweeps only)")
    return 0


def _default_transcript_dir(project_path: str) -> Path:
    """Claude Code stores transcripts under a slug of the project path."""
    slug = project_path.replace("/", "-").replace(".", "-").replace("_", "-")
    return Path.home() / ".claude" / "projects" / slug


def cmd_demo(_args) -> int:
    cfg = get_config()
    store = Store(cfg.db_path)
    embedder = get_embedder(cfg)
    project = _project(cfg, _args)
    sample = "\n".join(
        [
            "The recall hook injects memory just-in-time via additionalContext.",
            "Capture runs in a detached worker so it costs zero interactive tokens.",
            "Embeddings are quantised to int8 to keep the store compact.",
            "Project identity uses marker-walk, not basename of the working directory.",
            "SessionStart injects a small stable core that stays cache-friendly.",
        ]
    )
    n = service.capture_text(store, embedder, cfg, project, "demo", sample)
    print(f"captured {n} demo fact(s) into {project['label']}\n")
    query = "how does recall inject memory into context"
    print(f"recall query: {query!r}\n")
    print(service.recall_prompt_block(store, embedder, cfg, project, query) or "(no hit)")
    store.close()
    return 0


def _import_resolver(store: Store, cfg, maps: dict[str, str]):
    """Label → engram Project. `--map LABEL=/abs/path` wins; else an existing engram project
    with that label (its stored key is reused); else None → the label is skipped, never guessed.

    A `--map` path is run through `resolve_project` so it derives the *same* key engram would
    use for that workspace — so migrated facts land under the live project's key.
    """
    existing = {
        r["project_label"]: {"key": r["project_key"], "label": r["project_label"], "path": r["project_path"] or ""}
        for r in store.projects()
    }

    def resolve(label: str):
        if label in maps:
            return resolve_project(None, cfg.markers, identity="workspace", project_dir=maps[label])
        return existing.get(label)

    return resolve


def _print_import_plan(plan: dict, source: str) -> None:
    if not plan.get("available"):
        return
    print(f"[dry-run] {source} → engram")
    for label, info in plan["projects"].items():
        print(f"  {label:24s} [{info['key']}]  {info['would_import']:>7,} fact(s) would import")
    if plan["skipped"]:
        print(f"  skipped (no mapping — pass --map {plan['skipped'][0]}=/abs/path): {', '.join(plan['skipped'])}")


def _print_import_result(result: dict) -> None:
    print("imported into engram:")
    for label, info in result["projects"].items():
        print(f"  {label:24s} [{info['key']}]  inserted {info['inserted']:,}, reinforced {info['reinforced']:,}")
    if result["skipped"]:
        print(f"  skipped (no mapping): {', '.join(result['skipped'])}")


def _confirm_import(total: int) -> bool:
    """Gate a real (non-dry) import. Requires an interactive TTY; otherwise --yes is mandatory."""
    if not sys.stdin.isatty():
        print(f"refusing to import {total:,} fact(s) without --yes in a non-interactive shell", file=sys.stderr)
        return False
    return input(f"import {total:,} fact(s) into engram? [y/N] ").strip().lower() in ("y", "yes")


def cmd_import(args) -> int:
    from core.migrate import import_memory_source
    from core.ports.memory_source import get_memory_source

    cfg = get_config()
    store = Store(cfg.db_path)
    embedder = get_embedder(cfg)
    source = get_memory_source(args.source, db_path=args.db)
    try:
        if not source.available():
            where = f" at {args.db}" if args.db else ""
            print(f"no readable {args.source} store{where} — nothing to import", file=sys.stderr)
            return 1

        maps: dict[str, str] = {}
        for entry in args.map or []:
            if "=" not in entry:
                print(f"ignoring --map {entry!r} (expected LABEL=/abs/path)", file=sys.stderr)
                continue
            label, path = entry.split("=", 1)
            maps[label.strip()] = path.strip()
        resolve = _import_resolver(store, cfg, maps)

        # When not skipping the gate, show a dry-run plan first and confirm.
        if args.dry_run or not args.yes:
            plan = import_memory_source(store, embedder, cfg, source, resolve, only_label=args.project, dry_run=True)
            _print_import_plan(plan, args.source)
            if args.dry_run:
                return 0
            total = sum(p["would_import"] for p in plan["projects"].values())
            if total == 0:
                print("nothing to import (no mappable projects — see skipped above)")
                return 0
            if not _confirm_import(total):
                print("aborted — no changes made")
                return 1

        def progress(counts: dict) -> None:
            if counts["batches"] % 20 == 0:
                print(f"  … {counts['inserted']:,} inserted / {counts['reinforced']:,} reinforced", file=sys.stderr)

        result = import_memory_source(
            store, embedder, cfg, source, resolve, only_label=args.project, batch=args.batch, progress=progress
        )
        _print_import_result(result)
        scope = "" if args.project else " --all"
        print(f"\n→ run 'engram consolidate{scope}' to compress the imported facts")
        return 0
    finally:
        source.close()
        store.close()


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="engram", description="claude-engram memory CLI")
    sub = parser.add_subparsers(dest="cmd", required=True)

    def add_cwd(p):
        p.add_argument("--cwd", help="project working directory (default: current)")

    p = sub.add_parser("doctor", help="show config and status")
    add_cwd(p)
    p.set_defaults(func=cmd_doctor)

    p = sub.add_parser("capture", help="capture memory")
    add_cwd(p)
    p.add_argument("--file", help="capture from a text file")
    p.add_argument("--transcript", help="capture from a Claude Code JSONL transcript")
    p.add_argument("--session", help="session id label")
    p.set_defaults(func=cmd_capture)

    p = sub.add_parser("recall", help="run a recall query")
    add_cwd(p)
    p.add_argument("query")
    p.set_defaults(func=cmd_recall)

    p = sub.add_parser("core", help="show the session-start core block")
    add_cwd(p)
    p.set_defaults(func=cmd_core)

    p = sub.add_parser("projects", help="list all projects")
    p.set_defaults(func=cmd_projects)

    p = sub.add_parser("prune", help="delete this project's memory")
    add_cwd(p)
    p.set_defaults(func=cmd_prune)

    p = sub.add_parser("uninstall", help="uninstall the plugin, keeping memory (--purge-data to remove it)")
    p.add_argument("--purge-data", action="store_true", help="also delete the memory store + venv (explicit opt-in)")
    p.add_argument("--dry-run", action="store_true", help="print what would happen; change nothing")
    p.set_defaults(func=cmd_uninstall)

    p = sub.add_parser("import", help="migrate memory from another store (e.g. claude-mem) into engram")
    p.add_argument("source", choices=["claude-mem"], help="source store to import from")
    p.add_argument("--db", help="path to the source store (default: resolved from its settings/env)")
    p.add_argument("--project", metavar="LABEL", help="import only this source project label")
    p.add_argument(
        "--map",
        action="append",
        metavar="LABEL=/abs/path",
        help="map a source label to an engram project path (repeatable); else an existing project with that label is reused",
    )
    p.add_argument("--dry-run", action="store_true", help="report what would import, per project; write nothing")
    p.add_argument("--batch", type=int, default=256, help="embedding batch size (default: 256)")
    p.add_argument(
        "--yes", action="store_true", help="skip the confirmation prompt (required in non-interactive shells)"
    )
    p.set_defaults(func=cmd_import)

    p = sub.add_parser("sweep", help="archive stale facts (TTL expiry)")
    add_cwd(p)
    p.add_argument("--days", type=float, default=0, help="TTL in days (default: config ttl_days)")
    p.add_argument("--all", action="store_true", help="sweep every project, not just the current one")
    p.set_defaults(func=cmd_sweep)

    p = sub.add_parser(
        "consolidate",
        help="run the sleep pass: replay (promote) + integrate (merge, opt-in) + refine (prune, opt-in)",
    )
    add_cwd(p)
    p.add_argument("--all", action="store_true", help="consolidate every project, not just the current one")
    p.set_defaults(func=cmd_consolidate)

    p = sub.add_parser("setup", help="provision the private fastembed venv (one-time)")
    p.set_defaults(func=cmd_setup)

    p = sub.add_parser("daemon", help="run the resident daemon")
    p.set_defaults(func=cmd_daemon)

    p = sub.add_parser("viewer", help="launch the localhost viewer")
    p.add_argument("--port", type=int, default=7801)
    p.add_argument("--no-open", action="store_true", help="do not open a browser")
    p.add_argument("--ensure", action="store_true", help="ensure the resident viewer is up (detached), then open it")
    p.add_argument("--stop", action="store_true", help="stop the resident viewer")
    p.set_defaults(func=cmd_viewer)

    p = sub.add_parser("stats", help="recall telemetry + token-savings ledger (cost vs saved, net)")
    add_cwd(p)
    p.add_argument("--all", action="store_true", help="aggregate across every project")
    p.set_defaults(func=cmd_stats)

    p = sub.add_parser("queue", help="inspect / purge the durable work queue (rescue backlog + dead-letter)")
    add_cwd(p)
    p.add_argument("--all", action="store_true", help="list across every project (default: current)")
    p.add_argument("--purge-dead", action="store_true", help="delete dead-lettered items")
    p.add_argument("--purge-stage", metavar="STAGE", help="delete items of a stage (e.g. rescue)")
    p.add_argument("--purge-all", action="store_true", help="delete ALL work items")
    p.set_defaults(func=cmd_queue)

    p = sub.add_parser("drift", help="pin/check the embedding-drift canary")
    p.set_defaults(func=cmd_drift)

    p = sub.add_parser("eval", help="benchmark embedding backends on a labelled recall set")
    p.add_argument("--backends", default="hash", help="comma-separated: hash,fastembed")
    p.add_argument("--stm", action="store_true", help="also run the STM-tier lever (stm_recall_weight) scenario")
    p.set_defaults(func=cmd_eval)

    p = sub.add_parser("replay", help="counterfactual token savings from past session transcripts")
    add_cwd(p)
    p.add_argument("--transcript-dir", help="transcript directory (default: this project's)")
    p.set_defaults(func=cmd_replay)

    p = sub.add_parser("demo", help="capture sample facts then recall")
    p.set_defaults(func=cmd_demo)

    return parser


def main() -> int:
    args = build_parser().parse_args()
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
